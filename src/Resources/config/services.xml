<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="SanalposproPayment\ScheduledTask\ExampleTask">
            <tag name="shopware.scheduled.task"/>
        </service>

        <service id="SanalposproPayment\Subscriber\MySubscriber">
            <tag name="kernel.event_subscriber"/>
        </service>

        <service id="SanalposproPayment\Storefront\Controller\ExampleController" public="true">
            <call method="setContainer">
                <argument type="service" id="service_container"/>
            </call>
        </service>

        <service id="SanalposproPayment\Core\Content\Example\SalesChannel\ExampleRoute">
            <argument type="service" id="product.repository"/>
        </service>

        <service id="SanalposproPayment\Core\Content\Yes\YesDefinition">
            <tag name="shopware.entity.definition" entity="yes" />
        </service>

        <!-- Dev 1 — Task 1.1: DAL entities (Contract C column names) -->
        <service id="SanalposproPayment\Core\Content\WebhookLog\WebhookLogDefinition">
            <tag name="shopware.entity.definition" entity="sanalpospro_webhook_log" />
        </service>

        <service id="SanalposproPayment\Core\Content\Installment\InstallmentDefinition">
            <tag name="shopware.entity.definition" entity="sanalpospro_installment" />
        </service>

        <service id="SanalposproPayment\Service\CustomFieldsInstaller">
            <argument type="service" id="custom_field_set.repository"/>
            <argument type="service" id="custom_field_set_relation.repository"/>
        </service>

    </services>
</container>